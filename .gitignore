# Environment
.env*
!.env.example

# Dependencies
node_modules/

# Claude Code local settings
.claude/settings.local.json

# Conversation logs (may contain sensitive prompts)
.logs/

# Session state (ephemeral, per-machine)
.claude/session-state/

# OS-generated files
.DS_Store
Thumbs.db

# Editor swap/backup files
*.swp
*~

# Internal project notes (per-machine, not shared)
.HUB/

# Ralph task runner runtime files (optional -- only needed if using ralph-tui)
.ralph-tui/iterations/
.ralph-tui/reports/
.ralph-tui/progress.md
.ralph-tui/session.json
.ralph-tui/session-meta.json
.ralph-tui/ralph.lock
